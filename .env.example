# ─── GroqCloud ───────────────────────────────────────────────────────────────
GROQ_API_KEY=my-groq-api-key-here
# Modèle principal — si décommissionné, le fallback prend la relève automatiquement
GROQ_MODEL=llama-3.3-70b-versatile
# Modèle de secours (utilisé automatiquement si GROQ_MODEL est décommissionné)
GROQ_MODEL_FALLBACK=llama-3.1-8b-instant
GROQ_TIMEOUT_MS=30000

# ─── MySQL ───────────────────────────────────────────────────────────────────
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=polycheck
MYSQL_PASSWORD=polycheck_secret
MYSQL_DATABASE=polycheck_db
MYSQL_ROOT_PASSWORD=root_secret

# ─── Backend ─────────────────────────────────────────────────────────────────
BACKEND_PORT=3001
NODE_ENV=development

# ─── Python Service ──────────────────────────────────────────────────────────
PYTHON_SERVICE_URL=http://python-service:8000
PYTHON_TIMEOUT_MS=10000

# ─── RAG (Retrieval Augmented Generation) ─────────────────────────────────────
# Active/désactive l'augmentation des prompts avec les bonnes pratiques (RAG)
RAG_ENABLED=true
# Chemin de persisten stockage de la base de patterns Chroma
CHROMA_DB_PATH=/tmp/polycheck_chroma

# ─── Limites ─────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_BYTES=51200
SUPPORTED_LANGUAGES=python,javascript,typescript,java,go,rust,c,cpp

# ─── MCP Server (PHP) ───────────────────────────────────────────────────────
# Port du serveur MCP (Model Context Protocol)
MCP_SERVER_PORT=3002

# ─── Frontend ────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3001
